DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINKING=disabled
DEEPSEEK_INTENT_TEMPERATURE=0

ES_URL=http://127.0.0.1:9200
ES_API_KEY=
ES_USER=
ES_PASSWORD=
ES_INDEX=customer_service_knowledge_v1
ES_SEARCH_MODE=rrf_mmr
ES_NUM_CANDIDATES=120
ES_TEXT_BOOST=0.2
ES_VECTOR_BOOST=1.0
ES_VECTOR_FIELD=content_vector
ES_CANDIDATE_K=12
ES_RRF_K=60
ES_MMR_LAMBDA=0.70
ES_DEDUP_THRESHOLD=0.88

# 业务工具运行态配置
BUSINESS_TOOL_DB=runtime/business_tools.db
BUSINESS_CONFIRM_TTL_SECONDS=600
BUSINESS_TOOL_MAX_RETRIES=3

# 多轮会话、槽位和可恢复任务状态
AGENT_STATE_DB=runtime/conversation_state.db

# Web/API、并发、限流、追踪和人工转接
WEB_HOST=127.0.0.1
WEB_PORT=8000
AGENT_MAX_CONCURRENCY=4
AGENT_REQUEST_TIMEOUT_SECONDS=90
AGENT_RATE_LIMIT_REQUESTS=20
AGENT_RATE_LIMIT_WINDOW_SECONDS=60
AGENT_CLARIFY_CONFIDENCE_THRESHOLD=0.50
AGENT_HANDOFF_CONFIDENCE_THRESHOLD=0.45
AGENT_HANDOFF_DB=runtime/handoffs.db
AGENT_LOG_PATH=runtime/agent.log

# 可选的 LLM Reranker
RERANK_ENABLED=false
RERANK_CONDITIONAL=true
RERANK_CANDIDATE_K=5
RERANK_MAX_DOC_CHARS=700
